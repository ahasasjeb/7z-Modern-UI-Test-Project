<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="SevenZipManager.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="设置"
    CloseButtonText="关闭"
    MinWidth="450">

    <ScrollViewer>
        <StackPanel Spacing="16">
            <Expander Header="常规" IsExpanded="True">
                <StackPanel Spacing="12">
                    <CheckBox x:Name="ShowHiddenFilesCheckBox" Content="显示隐藏文件"/>
                    <CheckBox x:Name="ShowSystemFilesCheckBox" Content="显示系统文件"/>
                    <CheckBox x:Name="ShowExtensionsCheckBox" Content="显示文件扩展名" IsChecked="True"/>
                    <CheckBox x:Name="DoubleClickOpenCheckBox" Content="双击打开文件/文件夹" IsChecked="True"/>
                </StackPanel>
            </Expander>

            <Expander Header="压缩设置">
                <StackPanel Spacing="12">
                    <TextBlock Text="默认压缩格式:"/>
                    <ComboBox x:Name="DefaultFormatComboBox" SelectedIndex="0">
                        <ComboBoxItem Content="7z"/>
                        <ComboBoxItem Content="ZIP"/>
                        <ComboBoxItem Content="TAR"/>
                    </ComboBox>
                    <TextBlock Text="默认压缩级别:"/>
                    <ComboBox x:Name="DefaultLevelComboBox" SelectedIndex="3">
                        <ComboBoxItem Content="最快"/>
                        <ComboBoxItem Content="较快"/>
                        <ComboBoxItem Content="普通"/>
                        <ComboBoxItem Content="最大"/>
                        <ComboBoxItem Content="极限"/>
                    </ComboBox>
                    <CheckBox x:Name="CreateSfxCheckBox" Content="创建自解压文件"/>
                </StackPanel>
            </Expander>

            <Expander Header="界面">
                <StackPanel Spacing="12">
                    <TextBlock Text="主题:"/>
                    <ComboBox x:Name="ThemeComboBox" SelectedIndex="0">
                        <ComboBoxItem Content="跟随系统"/>
                        <ComboBoxItem Content="浅色"/>
                        <ComboBoxItem Content="深色"/>
                    </ComboBox>
                    <TextBlock Text="语言:"/>
                    <ComboBox x:Name="LanguageComboBox" SelectedIndex="0">
                        <ComboBoxItem Content="简体中文"/>
                        <ComboBoxItem Content="繁體中文"/>
                        <ComboBoxItem Content="English"/>
                    </ComboBox>
                </StackPanel>
            </Expander>

            <Expander Header="关于">
                <StackPanel Spacing="8">
                    <TextBlock Text="7-Zip 文件管理器 (WinUI 3)" FontWeight="SemiBold"/>
                    <TextBlock Text="基于 7-Zip 26.00 核心" Opacity="0.7"/>
                    <TextBlock Text="使用 WinUI 3 构建现代化界面" Opacity="0.7"/>
                    <TextBlock Text="© 2026" Opacity="0.5"/>
                </StackPanel>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
