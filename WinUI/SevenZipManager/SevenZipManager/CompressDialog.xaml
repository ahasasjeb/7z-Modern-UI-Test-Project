<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="SevenZipManager.CompressDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="添加到压缩包"
    PrimaryButtonText="确定"
    CloseButtonText="取消"
    DefaultButton="Primary"
    MinWidth="400">

    <StackPanel Spacing="12">
        <TextBlock Text="选择压缩格式:" FontWeight="SemiBold"/>
        <ComboBox x:Name="FormatComboBox" SelectedIndex="0">
            <ComboBoxItem Content="7z"/>
            <ComboBoxItem Content="ZIP"/>
            <ComboBoxItem Content="TAR"/>
            <ComboBoxItem Content="GZIP"/>
            <ComboBoxItem Content="BZIP2"/>
            <ComboBoxItem Content="XZ"/>
        </ComboBox>

        <TextBlock Text="输出文件名:" FontWeight="SemiBold"/>
        <TextBox x:Name="FileNameBox" PlaceholderText="输入文件名..."/>

        <TextBlock Text="输出路径:" FontWeight="SemiBold"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="OutputPathBox" Grid.Column="0" IsReadOnly="True"/>
            <Button Grid.Column="1" Content="浏览..." Margin="8,0,0,0" Click="OnBrowseClick"/>
        </Grid>

        <TextBlock Text="压缩级别:" FontWeight="SemiBold"/>
        <ComboBox x:Name="LevelComboBox" SelectedIndex="3">
            <ComboBoxItem Content="最快"/>
            <ComboBoxItem Content="较快"/>
            <ComboBoxItem Content="普通"/>
            <ComboBoxItem Content="最大"/>
            <ComboBoxItem Content="极限"/>
        </ComboBox>

        <TextBlock Text="密码 (可选):" FontWeight="SemiBold"/>
        <PasswordBox x:Name="PasswordBox" PlaceholderText="输入密码..."/>

        <CheckBox x:Name="EncryptNamesCheckBox" Content="加密文件名 (仅7z格式)"/>
    </StackPanel>
</ContentDialog>
