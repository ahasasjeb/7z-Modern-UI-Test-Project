<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="SevenZipManager.ExtractDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="解压文件"
    PrimaryButtonText="确定"
    CloseButtonText="取消"
    DefaultButton="Primary"
    MinWidth="400">

    <StackPanel Spacing="12">
        <TextBlock Text="要解压的文件:" FontWeight="SemiBold"/>
        <TextBox x:Name="SourceFileBox" IsReadOnly="True"/>

        <TextBlock Text="解压到:" FontWeight="SemiBold"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="OutputPathBox" Grid.Column="0" IsReadOnly="True"/>
            <Button Grid.Column="1" Content="浏览..." Margin="8,0,0,0" Click="OnBrowseClick"/>
        </Grid>

        <TextBlock Text="密码 (如果需要):" FontWeight="SemiBold"/>
        <PasswordBox x:Name="PasswordBox" PlaceholderText="输入密码..."/>

        <CheckBox x:Name="OverwriteCheckBox" Content="覆盖现有文件" IsChecked="True"/>
        <CheckBox x:Name="CreateSubfolderCheckBox" Content="创建子文件夹" IsChecked="True"/>
    </StackPanel>
</ContentDialog>
