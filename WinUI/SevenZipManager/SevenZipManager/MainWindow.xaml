<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SevenZipManager.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SevenZipManager"
    Title="7-Zip 文件管理器">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid x:Name="TitleBar" Grid.Row="0" Padding="12,8">
            <TextBlock Text="7-Zip 文件管理器" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center" FontWeight="SemiBold"/>
        </Grid>

        <Grid Grid.Row="1" Margin="12,8,12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="128"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#22000000" BorderThickness="1" Padding="8" Margin="0,0,10,0">
                <StackPanel Spacing="6">
                    <Button Content="压缩" Click="OnCompressClick" HorizontalAlignment="Stretch"/>
                    <Button Content="解压" Click="OnExtractClick" HorizontalAlignment="Stretch"/>
                    <Button Content="刷新" Click="OnRefreshClick" HorizontalAlignment="Stretch"/>

                    <Border Height="1" Background="#22000000" Margin="0,4"/>

                    <Button Content="复制" Click="OnCopyClick" HorizontalAlignment="Stretch"/>
                    <Button Content="移动" Click="OnMoveClick" HorizontalAlignment="Stretch"/>
                    <Button Content="删除" Click="OnDeleteClick" HorizontalAlignment="Stretch"/>

                    <Border Height="1" Background="#22000000" Margin="0,4"/>

                    <Button Content="搜索" Click="OnSearchClick" HorizontalAlignment="Stretch"/>
                    <Button Content="设置" Click="OnSettingsClick" HorizontalAlignment="Stretch"/>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="&#xE72B;" FontFamily="Segoe MDL2 Assets" Click="OnParentFolderClick" Margin="0,0,8,0"/>
                    <AutoSuggestBox Grid.Column="1" x:Name="PathBox"
                                    PlaceholderText="输入路径..."
                                    QueryIcon="Go"
                                    Text="{x:Bind ViewModel.CurrentPath, Mode=TwoWay}"
                                    QuerySubmitted="OnPathQuerySubmitted"/>
                    <Button Grid.Column="2" Content="&#xE713;" FontFamily="Segoe MDL2 Assets" Click="OnRefreshClick" Margin="8,0,0,0"/>
                </Grid>

                <ListView Grid.Row="1" x:Name="FileListView"
                          ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}"
                          SelectionMode="Extended"
                          DoubleTapped="OnFileDoubleTapped">
                    <ListView.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="名称" FontWeight="SemiBold" Padding="8,4"/>
                            <TextBlock Grid.Column="2" Text="大小" FontWeight="SemiBold" Padding="8,4"/>
                            <TextBlock Grid.Column="3" Text="类型" FontWeight="SemiBold" Padding="8,4"/>
                            <TextBlock Grid.Column="4" Text="修改日期" FontWeight="SemiBold" Padding="8,4"/>
                        </Grid>
                    </ListView.Header>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:FileItem">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="150"/>
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="{x:Bind Icon}" FontSize="16" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="1" Text="{x:Bind Name}" Padding="0,4"/>
                                <TextBlock Grid.Column="2" Text="{x:Bind SizeText}" Padding="8,4"/>
                                <TextBlock Grid.Column="3" Text="{x:Bind Type}" Padding="8,4"/>
                                <TextBlock Grid.Column="4" Text="{x:Bind Modified}" Padding="8,4"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>

        <Grid Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" Padding="12,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="StatusText" Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"/>
            <ProgressBar Grid.Column="1" Height="4" Margin="12,0"
                         IsIndeterminate="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                         Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}"
                         Minimum="0" Maximum="100"/>
            <TextBlock Grid.Column="2" x:Name="ItemCountText" Text="{x:Bind ViewModel.ItemCountText, Mode=OneWay}"/>
        </Grid>
    </Grid>
</Window>
